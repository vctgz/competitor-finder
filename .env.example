# Competitor Finder — environment

# REQUIRED — DataForSEO Google Maps API (store lookup + nearby competitor search).
# The password is your API password, not your account password. Sign up at dataforseo.com.
DATAFORSEO_LOGIN=you@example.com
DATAFORSEO_PASSWORD=your_api_password

# REQUIRED for the market brief + relevance filter (the AI features). Without it the tool
# still finds competitors by each store's own Google category, just with no brief.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown). Brief = market read; filter = relevance.
# COMPFINDER_BRIEF_MODEL=claude-sonnet-4-6
# COMPFINDER_FILTER_MODEL=claude-haiku-4-5

# Optional tunables (defaults shown).
# COMPFINDER_COUNT=10            # default competitors per location
# COMPFINDER_LOCATION=United States
# COMPFINDER_MAX_ROWS=250
# COMPFINDER_PORT=8001           # local Python server port

# The Cloudflare Worker reads DATAFORSEO_LOGIN/PASSWORD + ANTHROPIC_API_KEY as encrypted
# secrets (wrangler secret put ...) and the COMPFINDER_* tunables from worker/wrangler.toml.
